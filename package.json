{
	"name": "adguard-blocklist",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"lint": "prettier --check . && eslint .",
		"format": "prettier --write .",
		"prepare": "svelte-kit sync || echo ''",
		"dev": "svelte-kit sync && vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"bb": "yarn build && yarn preview",
		"cf:build": "vite build",
		"cf:dev": "wrangler dev .svelte-kit/cloudflare/_worker.js",
		"cf:deploy:worker": "wrangler deploy .svelte-kit/cloudflare/_worker.js",
		"cf:pages:dev": "wrangler pages dev .svelte-kit/cloudflare",
		"cf:pages:deploy": "wrangler pages deploy .svelte-kit/cloudflare"
	},
	"devDependencies": {
		"@sveltejs/adapter-auto": "^6.0.0",
		"@sveltejs/adapter-cloudflare": "^7.2.4",
		"@eslint/compat": "^2.0.4",
		"@eslint/js": "^10.0.1",
		"@sveltejs/kit": "^2.57.0",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@tailwindcss/typography": "^0.5.19",
		"@tailwindcss/vite": "^4.2.2",
		"@types/node": "^24",
		"@types/toastify-js": "^1.12.4",
		"eslint": "^10.2.0",
		"eslint-plugin-svelte": "^3.17.0",
		"globals": "^17.4.0",
		"prettier": "^3.8.1",
		"prettier-plugin-svelte": "^3.5.1",
		"prettier-plugin-tailwindcss": "^0.7.2",
		"svelte": "^5.55.2",
		"svelte-check": "^4.4.6",
		"tailwindcss": "^4.2.2",
		"typescript": "^6.0.2",
		"typescript-eslint": "^8.58.1",
		"vite": "^8.0.7"
	},
	"dependencies": {
		"toastify-js": "^1.12.0"
	},
	"packageManager": "yarn@4.5.0"
}
